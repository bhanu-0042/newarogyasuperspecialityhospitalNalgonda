API_PORT=3001
VITE_API_URL=http://localhost:3001
ORACLE_USER=your_oracle_user
ORACLE_PASSWORD=your_oracle_password
ORACLE_CONNECTION_STRING=localhost:1521/ORCL
# If your local Oracle instance is the second one on this machine, use:
# ORACLE_CONNECTION_STRING=localhost:1522/orclRoo
BOOKINGS_DB_DRIVER=oracledb
# For Oracle 10g on this machine, use the Java JDBC helper:
# BOOKINGS_DB_DRIVER=jdbc
# BOOKINGS_JDBC_DRIVER_JAR=C:\\oracle\\product\\10.2.0\\db_2\\jdbc\\lib\\ojdbc14.jar
# Optional: only needed if you want Thick mode
ORACLE_CLIENT_LIB_DIR=C:\\oracle\\instantclient_23_5

# Admin access for the protected bookings dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_now
ADMIN_AUTH_SECRET=replace_with_a_long_random_secret
